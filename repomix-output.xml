// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  RESPONSABLE
  AGENT
}

enum Priority {
  P1
  P2
  P3
  P4
}

model Ticket {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title       String
  description String?
  status      String    @default("OPEN")
  priority    Priority  @default(P3)
  dueDate     DateTime?

  environmentId Int
  environment   Environment @relation(fields: [environmentId], references: [id])

  leadId Int?
  lead  Lead? @relation(fields: [leadId], references: [id], onDelete: Cascade)

  assigneeId Int?
  assignee   User? @relation("TicketAssignee", fields: [assigneeId], references: [id])

  creatorId Int
  creator   User @relation("TicketCreator", fields: [creatorId], references: [id])

  @@map("tickets")
}

model ChecklistItem {
  id         Int     @id @default(autoincrement())
  label      String
  isRequired Boolean @default(true)

  stepId Int
  step   WorkflowStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  leadResponses LeadChecklistResponse[]

  @@map("checklist_items")
}

model DocumentRequirement {
  id         Int     @id @default(autoincrement())
  label      String
  isRequired Boolean @default(true)

  stepId Int
  step   WorkflowStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  leadDocuments LeadDocument[]

  @@map("document_requirements")
}

model LeadChecklistResponse {
  id        Int     @id @default(autoincrement())
  isChecked Boolean @default(false)

  leadId Int
  lead   Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  checklistItemId Int
  checklistItem   ChecklistItem @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)

  @@unique([leadId, checklistItemId])
  @@map("lead_checklist_responses")
}

model LeadDocument {
  id       Int      @id @default(autoincrement())
  fileUrl  String
  uploadAt DateTime @default(now())

  leadId Int
  lead   Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  requirementId Int?
  requirement   DocumentRequirement? @relation(fields: [requirementId], references: [id], onDelete: SetNull)

  @@map("lead_documents")
}

model WorkflowStep {
  id      Int     @id @default(autoincrement())
  name    String
  color   String?
  order   Int
  isFinal Boolean @default(false)

  environmentId Int
  environment   Environment @relation(fields: [environmentId], references: [id])

  leads                Lead[]
  checklistItems       ChecklistItem[]
  documentRequirements DocumentRequirement[]

  @@unique([name, environmentId])
  @@map("workflow_steps")
}

model LeadHistory {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  action   String
  oldValue String?
  newValue String?

  leadId Int
  lead   Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  userId Int?
  user   User? @relation(fields: [userId], references: [id])

  @@map("lead_histories")
}

model Lead {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  firstName String?
  lastName  String?
  email     String?
  phone     String

  source String

  stepId Int?
  step   WorkflowStep? @relation(fields: [stepId], references: [id])

  lastCallRecordUrl String? @db.Text
  aiSummary         String? @db.Text

  environmentId Int
  environment   Environment @relation(fields: [environmentId], references: [id])

  agentId Int?
  agent   User? @relation(fields: [agentId], references: [id])

  histories              LeadHistory[]
  leadChecklistResponses LeadChecklistResponse[]
  leadDocuments          LeadDocument[]
  tickets                Ticket[]

  @@map("leads")
}

model Environment {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name        String
  description String?

  users         User[]
  leads         Lead[]
  workflowSteps WorkflowStep[]
  tickets       Ticket[]
  @@map("environments")
}

model User {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  email String @unique
  hash  String

  firstname String?
  lastname  String?

  role          Role         @default(AGENT)
  environmentId Int?
  environment   Environment? @relation(fields: [environmentId], references: [id])
  lead          Lead[]

  leadHistories LeadHistory[] 
  assignedTickets       Ticket[] @relation("TicketAssignee")
  createdTickets       Ticket[] @relation("TicketCreator")
  

  @@map("users")
}
