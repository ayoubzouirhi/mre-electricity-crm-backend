// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  RESPONSABLE
  AGENT
}

model WorkflowStep {
  id      Int     @id @default(autoincrement())
  name    String
  color   String?
  order   Int
  isFinal Boolean @default(false)

  environmentId Int
  environment   Environment @relation(fields: [environmentId], references: [id])

  leads Lead[]

  @@unique([name, environmentId])
  @@map("workflow_steps")
}

model LeadHistory {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  action   String
  oldValue String?
  newValue String?

  leadId Int
  lead   Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  userId Int?
  user   User? @relation(fields: [userId], references: [id])

  @@map("lead_histories")
}

model Lead {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  firstName String?
  lastName  String?
  email     String?
  phone     String

  source String

  stepId Int?
  step   WorkflowStep? @relation(fields: [stepId], references: [id])

  lastCallRecordUrl String? @db.Text
  aiSummary         String? @db.Text

  environmentId Int
  environment   Environment @relation(fields: [environmentId], references: [id])

  agentId Int?
  agent   User? @relation(fields: [agentId], references: [id])

  histories LeadHistory[]

  @@map("leads")
}

model Environment {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name        String
  description String?

  users         User[]
  leads         Lead[]
  workflowSteps WorkflowStep[]

  @@map("environments")
}

model User {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  email String @unique
  hash  String

  firstname String?
  lastname  String?

  role          Role         @default(AGENT)
  environmentId Int?
  environment   Environment? @relation(fields: [environmentId], references: [id])
  tbdel         Lead[]

  leadHistories LeadHistory[]

  @@map("users")
}
